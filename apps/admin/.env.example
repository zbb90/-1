ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASSWORD=change-this-before-deploy
# 可选：单独配置会话签名密钥；不填则使用 ADMIN_BASIC_AUTH_PASSWORD（生产建议单独设置）
ADMIN_SESSION_SECRET=
DASHSCOPE_API_KEY=
MODEL_NAME=qwen-plus
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=audit-regular-question-rules
SEMANTIC_RECALL_LIMIT=12

# --- 持久化存储（Upstash Redis） ---
# 本地开发可不填，自动使用 data/review-tasks.json
# 生产部署（如 Vercel）必须配置，否则复核数据无法持久保存
# 在 Vercel 控制台 → Storage → 创建 Upstash Redis → 自动注入以下两个变量
KV_REST_API_URL=
KV_REST_API_TOKEN=
