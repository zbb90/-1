# --- PC 端管理鉴权（兼容旧版 Basic Auth，可选） ---
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=
ADMIN_SESSION_SECRET=

# --- 三级账号体系 ---
# 负责人账号：格式 phone:password（多个逗号分隔）。第一条默认为「主负责人」，也可单独指定：
# PRIMARY_LEADER_PHONE=13800000001
LEADER_ACCOUNTS=13800000001:your-secure-password
# JWT 签名密钥（必填，生产环境请使用 32 字节以上随机串）
JWT_SECRET=change-this-to-a-random-string
# 小程序 JWT 过期秒数（可选，默认 604800=7 天；最短 300，最长 2592000=30 天）
# JWT_EXPIRES_SECONDS=604800
# 微信小程序凭证
WX_APPID=
WX_APP_SECRET=

# --- AI 模型 ---
DASHSCOPE_API_KEY=
MODEL_NAME=qwen3.5-flash
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

# --- 向量数据库 Qdrant ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=audit-regular-question-rules
SEMANTIC_RECALL_LIMIT=12

# --- 持久化存储（Redis） ---
# 本地开发可不填，自动使用 data/review-tasks.json
# 应用直接跑在宿主机上时可用：redis://127.0.0.1:6379/0
# 若应用运行在 Podman/Docker 容器内，推荐：redis://host.containers.internal:6379/0
REDIS_URL=
# 也可拆开配置：
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# REDIS_USERNAME=default
# REDIS_TLS=false
