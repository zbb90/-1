.page {
  padding: 24rpx 28rpx;
}

.result-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero {
  background: linear-gradient(145deg, #fef5f5, #ffffff);
  padding: 32rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-label {
  font-size: 24rpx;
  color: #86868b;
  font-weight: 500;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 800;
  color: #1d1d1f;
  letter-spacing: -0.02em;
}

.result-status {
  border-radius: 12rpx;
  padding: 10rpx 22rpx;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.danger {
  background: #ffe5e5;
  color: #d12c2c;
}

.safe {
  background: #e3f9e5;
  color: #1a7a3a;
}

.detail-card {
  display: flex;
  flex-direction: column;
  padding: 28rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
}

.detail-item + .detail-item {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f5;
}

.detail-label {
  font-size: 22rpx;
  color: #86868b;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.detail-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #1d1d1f;
}

.detail-desc {
  margin-top: 8rpx;
  color: #48484a;
  line-height: 1.8;
  font-size: 28rpx;
}

.strong {
  font-weight: 700;
  color: #1d1d1f;
}

.reason-item {
  margin-top: 12rpx;
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  color: #48484a;
  line-height: 1.7;
  font-size: 26rpx;
}

.reason-dot {
  margin-top: 12rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #34c759;
  flex-shrink: 0;
}

.secondary-button {
  background: #ffffff !important;
  color: #34c759 !important;
  border: 2rpx solid #b8e6c8 !important;
  border-radius: 14rpx;
  font-weight: 600;
}

.secondary-button::after {
  border: none;
}

.primary-button {
  background: linear-gradient(135deg, #34c759, #30b350) !important;
  color: #ffffff !important;
  border-radius: 14rpx;
  font-weight: 600;
}

.primary-button::after {
  border: none;
}

.empty-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 32rpx;
}

.neutral-text {
  color: #48484a;
}

.review-tip {
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #eef2ff;
  color: #3538cd;
  line-height: 1.7;
  font-size: 26rpx;
}
