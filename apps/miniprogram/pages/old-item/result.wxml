<view class="page">
  <view wx:if="{{matched && answer}}" class="result-stack">
    <view class="hero card">
      <view class="hero-top">
        <view>
          <view class="hero-label">旧品判定</view>
          <view class="hero-title">{{answer.isOldItem === '是' ? '是旧品' : '不是旧品'}}</view>
        </view>
        <view class="result-status {{answer.isOldItem === '是' ? 'danger' : 'safe'}}">
          {{answer.isOldItem}}
        </view>
      </view>
    </view>

    <view class="card detail-card">
      <view class="section-title">命中结果</view>
      <view class="detail-item">
        <view class="detail-label">物品名称</view>
        <view class="detail-value strong">{{answer.name}}</view>
      </view>
      <view class="detail-item">
        <view class="detail-label">命中清单</view>
        <view class="detail-desc">{{answer.sourceName}}</view>
      </view>
      <view class="detail-item">
        <view class="detail-label">识别备注</view>
        <view class="detail-desc">{{answer.remark}}</view>
      </view>
    </view>

    <view wx:if="{{answer.aiExplanation}}" class="card detail-card">
      <view class="section-title">AI 解释</view>
      <view class="detail-desc">{{answer.aiExplanation}}</view>
    </view>

    <view class="card">
      <view class="section-title">命中原因</view>
      <view wx:for="{{answer.matchedReasons}}" wx:key="*this" class="reason-item">
        <view class="reason-dot"></view>
        <view>{{item}}</view>
      </view>
    </view>

    <button class="secondary-button" bindtap="goBack">返回修改</button>
  </view>

  <view wx:else class="card empty-card">
    <view class="hero-label">无法判断</view>
    <view class="hero-title neutral-text">请补充更清晰名称或图片</view>
    <view class="detail-desc">{{rejectReason}}</view>
    <view wx:if="{{reviewTask}}" class="review-tip">
      已自动进入复核池：{{reviewTask.id}}｜{{reviewTask.status}}
    </view>
    <button wx:if="{{reviewTask}}" class="primary-button" bindtap="goToReviewDetail">
      查看复核详情
    </button>
    <button class="secondary-button" bindtap="goBack">返回修改</button>
  </view>
</view>
