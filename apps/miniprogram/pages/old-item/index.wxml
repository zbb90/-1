<view class="page">
  <view class="card">
    <view class="section-title">旧品比对</view>

    <view class="field">
      <view class="label">物品名称</view>
      <input
        class="input"
        placeholder="例如：工帽、仓垫板"
        value="{{name}}"
        bindinput="handleNameInput"
      />
    </view>

    <view class="field">
      <view class="label">备注说明</view>
      <textarea
        class="textarea"
        placeholder="例如：门店现场使用旧版工帽，颜色和当前版本不一致。"
        value="{{remark}}"
        bindinput="handleRemarkInput"
      />
    </view>

    <view class="tips">一期先用“名称 + 备注”完成比对，图片入口后续补入。</view>

    <button class="submit" type="primary" loading="{{loading}}" bindtap="handleSubmit">
      开始比对
    </button>
  </view>
</view>
