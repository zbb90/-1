.page {
  padding: 24rpx 28rpx;
  min-height: 100vh;
}

.profile-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, #f5faf6, #ffffff);
}

.profile-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.profile-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #34c759, #30b350);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-info {
  min-width: 0;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d1d1f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-id {
  font-size: 22rpx;
  color: #aeaeb2;
  font-family: "SF Mono", "Menlo", monospace;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 6rpx;
}

.profile-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.role-badge {
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.role-supervisor {
  background: #e8f8ee;
  color: #1a7a3a;
}

.role-specialist {
  background: #e8f0fe;
  color: #1a56db;
}

.settings-icon {
  font-size: 36rpx;
  color: #c7c7cc;
  line-height: 1;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.entry {
  display: flex;
  align-items: center;
  padding: 26rpx 28rpx;
  gap: 20rpx;
}

.entry-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.entry-icon-green {
  background: #e8f8ee;
}

.entry-icon-blue {
  background: #e8f0fe;
}

.entry-icon-orange {
  background: #fff3e0;
}

.entry-icon-purple {
  background: #f3e8ff;
}

.entry-body {
  flex: 1;
  min-width: 0;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.entry-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #86868b;
  line-height: 1.5;
}

.entry-arrow {
  font-size: 32rpx;
  color: #c7c7cc;
  flex-shrink: 0;
  line-height: 1;
}

.entry-disabled {
  opacity: 0.55;
}

.entry-disabled .entry-title {
  color: #6e6e73;
}

.entry-disabled .entry-desc {
  color: #a1a1a6;
}

.entry-badge {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #f2f2f7;
  color: #8e8e93;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}
