<view class="page">

  <view class="profile-card card" bindtap="goToSettings">
    <view class="profile-left">
      <view class="profile-avatar">{{avatarLetter}}</view>
      <view class="profile-info">
        <view class="profile-name">{{displayName}}</view>
        <view class="profile-id">{{requesterId}}</view>
      </view>
    </view>
    <view class="profile-right">
      <view wx:if="{{isSupervisor}}" class="role-badge role-supervisor">主管</view>
      <view wx:else class="role-badge role-specialist">专员</view>
      <view class="settings-icon">›</view>
    </view>
  </view>

  <view class="entry-list">
    <view class="entry card" bindtap="goToRegularQuestion">
      <view class="entry-icon entry-icon-green">📋</view>
      <view class="entry-body">
        <view class="entry-title">常规问题</view>
        <view class="entry-desc">扣不扣分、扣几分、依据条款</view>
      </view>
      <view class="entry-arrow">›</view>
    </view>

    <view class="entry card" bindtap="goToOldItem">
      <view class="entry-icon entry-icon-blue">🔍</view>
      <view class="entry-body">
        <view class="entry-title">旧品比对</view>
        <view class="entry-desc">名称 + 备注，返回是否旧品</view>
      </view>
      <view class="entry-arrow">›</view>
    </view>

    <view class="entry card" bindtap="goToExternalPurchase">
      <view class="entry-icon entry-icon-orange">🛒</view>
      <view class="entry-body">
        <view class="entry-title">外购查询</view>
        <view class="entry-desc">可外购 / 不可外购 快速检索</view>
      </view>
      <view class="entry-arrow">›</view>
    </view>

    <view class="entry card" bindtap="goToMyReviews">
      <view class="entry-icon entry-icon-purple">📝</view>
      <view class="entry-body">
        <view class="entry-title">我的复核</view>
        <view class="entry-desc">
          <view wx:if="{{isSupervisor}}">查看所有人的复核任务</view>
          <view wx:else>查看处理中 / 已处理的任务</view>
        </view>
      </view>
      <view class="entry-arrow">›</view>
    </view>
  </view>

</view>
