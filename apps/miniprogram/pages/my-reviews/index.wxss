.page {
  padding: 24rpx 28rpx;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  background: #ffffff;
  color: #86868b;
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid #e8e8ed;
}

.tab-active {
  background: linear-gradient(135deg, #34c759, #30b350);
  color: #ffffff;
  border-color: transparent;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.review-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 24rpx 28rpx;
}

.review-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.review-id {
  font-size: 26rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.review-meta {
  margin-top: 6rpx;
  color: #86868b;
  font-size: 24rpx;
}

.review-status {
  flex-shrink: 0;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  background: #fef9ec;
  color: #8b5c10;
  font-size: 22rpx;
  font-weight: 700;
}

.review-desc {
  color: #48484a;
  line-height: 1.7;
  font-size: 28rpx;
}

.review-time {
  color: #aeaeb2;
  font-size: 22rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 32rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.empty-desc {
  color: #86868b;
  line-height: 1.7;
}
