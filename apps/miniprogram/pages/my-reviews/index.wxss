.page {
  padding: 24rpx 28rpx;
}

.reply-banner {
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #ecfdf5, #ffffff);
  border: 1rpx solid #b7ebc6;
}

.supervisor-banner {
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #eff6ff, #ffffff);
  border: 1rpx solid #bfdbfe;
}

.reply-banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #166534;
}

.reply-banner-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #2f6f45;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  background: #ffffff;
  color: #86868b;
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid #e8e8ed;
}

.tab-active {
  background: linear-gradient(135deg, #34c759, #30b350);
  color: #ffffff;
  border-color: transparent;
}

.tab-badge {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.24);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 34rpx;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.review-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 24rpx 28rpx;
}

.review-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.review-id {
  font-size: 26rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.review-meta {
  margin-top: 6rpx;
  color: #86868b;
  font-size: 24rpx;
}

.review-requester {
  margin-top: 8rpx;
  color: #54715c;
  font-size: 23rpx;
}

.review-status {
  flex-shrink: 0;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  background: #fef9ec;
  color: #8b5c10;
  font-size: 22rpx;
  font-weight: 700;
}

.review-status-replied {
  background: #ecfdf5;
  color: #166534;
}

.review-desc {
  color: #48484a;
  line-height: 1.7;
  font-size: 28rpx;
}

.reply-preview {
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  background: #f4fbf6;
  color: #2f3a33;
  font-size: 24rpx;
  line-height: 1.8;
}

.reply-preview-label {
  color: #166534;
  font-weight: 700;
}

.review-time {
  color: #aeaeb2;
  font-size: 22rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 32rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.empty-desc {
  color: #86868b;
  line-height: 1.7;
}
