.page {
  padding: 24rpx 28rpx;
}

.detail-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-card {
  background: linear-gradient(145deg, #edf2ff, #ffffff);
  padding: 32rpx;
}

.hero-label {
  font-size: 24rpx;
  color: #86868b;
  font-weight: 500;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: #1d1d1f;
  letter-spacing: -0.02em;
}

.hero-desc {
  margin-top: 10rpx;
  color: #86868b;
  font-size: 26rpx;
}

.hero-reply-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #54715c;
}

.detail-item + .detail-item {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f5;
}

.detail-label {
  font-size: 22rpx;
  color: #86868b;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.detail-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #1d1d1f;
}

.detail-desc {
  margin-top: 8rpx;
  color: #48484a;
  line-height: 1.8;
  font-size: 28rpx;
}

.supervisor-tip {
  margin-top: 0;
  color: #54715c;
}

.picker-box {
  min-height: 88rpx;
  border: 2rpx solid #e8e8ed;
  border-radius: 14rpx;
  background: #fafafa;
  padding: 0 22rpx;
  line-height: 88rpx;
  color: #1d1d1f;
  font-size: 28rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 32rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.empty-desc {
  color: #86868b;
  line-height: 1.7;
}

/* 状态通知 */
.status-notice-pending {
  background: linear-gradient(145deg, #fef9ec, #ffffff);
  border-left: 6rpx solid #f5a623;
}

.status-notice-ai {
  background: linear-gradient(145deg, #edf2ff, #ffffff);
  border-left: 6rpx solid #3b82f6;
}

.status-notice-done {
  background: linear-gradient(145deg, #ecfdf5, #ffffff);
  border-left: 6rpx solid #34c759;
}

.reply-arrived-card {
  background: linear-gradient(145deg, #eff6ff, #ffffff);
  border-left: 6rpx solid #3b82f6;
}

.notice-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.notice-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #48484a;
  line-height: 1.8;
}

/* AI 答案 */
.ai-answer-block {
  margin-top: 16rpx;
  background: #edf2ff;
  border-radius: 14rpx;
  padding: 20rpx;
}

.ai-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.ai-label {
  font-size: 24rpx;
  color: #3538cd;
  min-width: 140rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.ai-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e3a5f;
}

.ai-explain {
  margin-top: 12rpx;
}

.ai-explain-text {
  font-size: 26rpx;
  color: #3538cd;
  line-height: 1.8;
}

.notice-actions {
  margin-top: 20rpx;
}

.btn-dispute {
  width: 100%;
  background: #ff3b30 !important;
  color: #ffffff !important;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 0;
  border: none;
}

.btn-dispute::after {
  border: none;
}

.btn-dispute[disabled] {
  background: #ffb3b0 !important;
}

.result-conclusion {
  color: #1a7a3a;
  font-weight: 700;
  font-size: 32rpx;
}
