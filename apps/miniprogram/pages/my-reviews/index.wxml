<view class="page">
  <view wx:if="{{isSupervisor}}" class="supervisor-banner">
    <view class="reply-banner-title">主管模式</view>
    <view class="reply-banner-desc">当前展示全部专员问题，你可以点进详情直接回复。</view>
  </view>

  <view wx:if="{{unreadReplyCount > 0}}" class="reply-banner">
    <view class="reply-banner-title">主管已有 {{unreadReplyCount}} 条新回复</view>
    <view class="reply-banner-desc">页面会自动刷新，新回复会优先显示在列表前面。</view>
  </view>

  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab {{activeTab === item.key ? 'tab-active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="handleTabChange"
    >
      <text>{{item.label}}</text>
      <text wx:if="{{item.key === 'replied' && unreadReplyCount > 0}}" class="tab-badge">
        {{unreadReplyCount}}
      </text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card empty-card">
    <view class="empty-title">加载中...</view>
    <view class="empty-desc">正在读取你的复核任务。</view>
  </view>

  <view wx:elif="{{filteredReviews.length === 0}}" class="card empty-card">
    <view class="empty-title">当前没有任务</view>
    <view wx:if="{{isSupervisor && activeTab === 'processing'}}" class="empty-desc">
      当前没有待处理任务，你可以切换到“全部问题”查看历史专员问题并直接回复。
    </view>
    <view wx:elif="{{isSupervisor}}" class="empty-desc">
      当前筛选条件下没有记录，请切换其他页签查看。
    </view>
    <view wx:else class="empty-desc">所选状态下还没有对应的复核记录。</view>
  </view>

  <view wx:else class="review-list">
    <view
      wx:for="{{filteredReviews}}"
      wx:key="id"
      class="card review-card"
      data-id="{{item.id}}"
      bindtap="goToDetail"
    >
      <view class="review-top">
        <view>
          <view class="review-id">{{item.id}}</view>
          <view class="review-meta">{{item.type}}｜{{item.category}}</view>
          <view wx:if="{{isSupervisor}}" class="review-requester">
            提问人：{{item.requester}}｜门店：{{item.storeCode}}
          </view>
        </view>
        <view class="review-status {{item.hasUnreadReply ? 'review-status-replied' : ''}}">
          {{item.displayStatus}}
        </view>
      </view>

      <view class="review-desc">{{item.description}}</view>
      <view wx:if="{{item.replyPreview}}" class="reply-preview">
        <text class="reply-preview-label">主管回复：</text>{{item.replyPreview}}
      </view>
      <view class="review-time">更新时间：{{item.updatedAt}}</view>
    </view>
  </view>
</view>
