.page {
  padding: 24rpx 28rpx;
  min-height: 100vh;
}

.settings-card {
  padding: 28rpx;
}

.field-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.field-row.mt {
  margin-top: 20rpx;
}

.field-label {
  font-size: 26rpx;
  color: #86868b;
  width: 140rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.field-value {
  font-size: 28rpx;
  color: #1d1d1f;
  flex: 1;
}

.id-text {
  font-family: "SF Mono", "Menlo", monospace;
  font-size: 22rpx;
  color: #aeaeb2;
  word-break: break-all;
}

.name-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #aeaeb2;
  padding-left: 156rpx;
}

.form-group {
  margin-top: 20rpx;
}

.mt {
  margin-top: 20rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-row .btn {
  flex: 1;
}

.flex-1 {
  flex: 1;
}

.supervisor-active {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.supervisor-badge {
  display: inline-block;
  background: #e8f8ee;
  color: #1a7a3a;
  border-radius: 999rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  align-self: flex-start;
}

.supervisor-tip {
  font-size: 26rpx;
  color: #86868b;
  line-height: 1.6;
}
