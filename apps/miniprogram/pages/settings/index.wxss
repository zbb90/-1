.page {
  padding: 32rpx;
  min-height: 100vh;
  background: #f7f8fa;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #6b7280;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-top: 40rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.field-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.field-row.mt {
  margin-top: 24rpx;
}

.field-label {
  font-size: 28rpx;
  color: #6b7280;
  width: 140rpx;
  flex-shrink: 0;
}

.field-value {
  font-size: 28rpx;
  color: #111827;
  flex: 1;
}

.id-text {
  font-family: monospace;
  font-size: 24rpx;
  color: #6b7280;
  word-break: break-all;
}

.input {
  flex: 1;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #111827;
  background: #f9fafb;
}

.form-group {
  margin-top: 24rpx;
}

.mt {
  margin-top: 24rpx;
}

.btn {
  display: block;
  width: 100%;
  border-radius: 18rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  box-sizing: border-box;
}

.btn-primary {
  background: #15803d;
  color: #ffffff;
}

.btn-outline {
  background: #ffffff;
  color: #374151;
  border: 2rpx solid #d1d5db;
}

.btn-danger {
  background: #ffffff;
  color: #dc2626;
  border: 2rpx solid #fca5a5;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-row .btn {
  flex: 1;
}

.flex-1 {
  flex: 1;
}

.supervisor-active {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.supervisor-badge {
  display: inline-block;
  background: #dcfce7;
  color: #15803d;
  border-radius: 999rpx;
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  align-self: flex-start;
}

.supervisor-tip {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}
