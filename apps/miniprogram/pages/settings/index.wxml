<view class="page">

  <!-- 专员身份 -->
  <view class="section-title">我的身份</view>
  <view class="card">
    <view class="field-row">
      <view class="field-label">专员 ID</view>
      <view class="field-value id-text">{{requesterId}}</view>
    </view>
    <view class="field-row mt">
      <view class="field-label">显示昵称</view>
      <input
        class="input"
        value="{{displayName}}"
        placeholder="输入你的姓名或工号"
        bindinput="handleNameInput"
        confirm-type="done"
        bindconfirm="saveName"
      />
    </view>
    <button class="btn btn-primary mt" bindtap="saveName">保存昵称</button>
  </view>

  <!-- 主管模式 -->
  <view class="section-title">主管模式</view>
  <view class="card">
    <view wx:if="{{isSupervisor}}" class="supervisor-active">
      <view class="supervisor-badge">主管模式已开启</view>
      <view class="supervisor-tip">你现在可以在「我的复核」中查看全部专员的复核任务。</view>
      <button class="btn btn-danger mt" bindtap="exitSupervisorMode">退出主管模式</button>
    </view>

    <view wx:else>
      <view class="supervisor-tip">主管登录后可在小程序查看所有复核任务（与 PC 端后台数据相同）。</view>
      <button
        class="btn btn-outline mt"
        bindtap="toggleSupervisorForm"
      >{{showSupervisorForm ? '收起' : '主管登录'}}</button>

      <view wx:if="{{showSupervisorForm}}" class="form-group mt">
        <view class="field-row">
          <view class="field-label">账号</view>
          <input
            class="input"
            value="{{supervisorUser}}"
            placeholder="主管账号（默认 admin）"
            bindinput="handleSupervisorUserInput"
          />
        </view>
        <view class="field-row mt">
          <view class="field-label">密码</view>
          <input
            class="input"
            password
            value="{{supervisorPass}}"
            placeholder="主管密码（默认 audit2026）"
            bindinput="handleSupervisorPassInput"
          />
        </view>
        <button class="btn btn-primary mt" bindtap="saveSupervisorAuth">确认登录</button>
      </view>
    </view>
  </view>

  <!-- 开发调试（仅在开发者工具中显示） -->
  <view wx:if="{{isDevTools}}">
    <view class="section-title">开发调试</view>
    <view class="card">
      <view class="supervisor-tip">当前默认接口地址为线上服务器。如需联调本地服务，可手动切换。</view>
      <view class="field-row mt">
        <view class="field-label">接口地址</view>
        <input
          class="input"
          value="{{apiOriginInput}}"
          placeholder="留空=默认线上"
          bindinput="handleApiOriginInput"
        />
      </view>
      <view class="btn-row mt">
        <button class="btn btn-outline flex-1" bindtap="useLocalOrigin">切到本地</button>
        <button class="btn btn-outline flex-1" bindtap="resetApiOrigin">恢复线上</button>
      </view>
      <button class="btn btn-primary mt" bindtap="saveApiOrigin">保存地址</button>
    </view>
  </view>

</view>
