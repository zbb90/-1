<view class="page">
  <view class="card">
    <view class="section-title">外购查询</view>

    <view class="field">
      <view class="label">物品名称</view>
      <input
        class="input"
        placeholder="例如：保鲜膜、杀虫剂"
        value="{{name}}"
        bindinput="handleNameInput"
      />
    </view>

    <view class="field">
      <view class="label">补充描述（选填）</view>
      <textarea
        class="textarea"
        placeholder="例如：门店使用喷雾杀虫剂，放在操作区域附近。"
        value="{{description}}"
        bindinput="handleDescriptionInput"
      />
    </view>

    <button class="submit" type="primary" loading="{{loading}}" bindtap="handleSubmit">
      开始查询
    </button>
  </view>
</view>
