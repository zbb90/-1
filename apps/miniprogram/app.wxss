page {
  background: #f5f5f7;
  color: #1d1d1f;
  font-size: 28rpx;
  font-family:
    -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC",
    "Helvetica Neue", sans-serif;
  -webkit-font-smoothing: antialiased;
}

.page {
  min-height: 100vh;
  padding: 24rpx 28rpx env(safe-area-inset-bottom);
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04), 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #86868b;
  letter-spacing: 0.06em;
  margin-top: 36rpx;
  margin-bottom: 14rpx;
  padding-left: 4rpx;
}

.section-title:first-child {
  margin-top: 0;
}

.input,
.textarea {
  display: block;
  width: 100%;
  border: 2rpx solid #e8e8ed;
  border-radius: 14rpx;
  background: #fafafa;
  font-size: 28rpx;
  color: #1d1d1f !important;
  transition: border-color 0.2s;
  box-sizing: border-box;
}

.input {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 22rpx;
}

.input:focus,
.textarea:focus {
  border-color: #34c759;
}

.textarea {
  padding: 20rpx 22rpx;
  min-height: 200rpx;
  line-height: 1.6;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  border-radius: 14rpx;
  padding: 22rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  box-sizing: border-box;
  line-height: 1;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #34c759, #30b350);
  color: #ffffff;
}

.btn-outline {
  background: #ffffff;
  color: #1d1d1f;
  border: 2rpx solid #d2d2d7;
}

.btn-danger {
  background: #ffffff;
  color: #ff3b30;
  border: 2rpx solid #ffb3b0;
}

.submit {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #34c759, #30b350) !important;
  color: #ffffff !important;
  border-radius: 14rpx;
  font-weight: 600;
  font-size: 30rpx;
}

.submit::after {
  border: none;
}

.field {
  margin-top: 24rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #86868b;
  font-size: 24rpx;
  font-weight: 500;
}

.detail-desc {
  margin-top: 8rpx;
  color: #48484a;
  line-height: 1.75;
  font-size: 28rpx;
}

.strong {
  font-weight: 600;
  color: #1d1d1f;
}
