{
  "name": "audit-ai-assistant",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace @audit-ai/admin",
    "lint:admin": "npm run lint --workspace @audit-ai/admin",
    "build:admin": "npm run build --workspace @audit-ai/admin",
    "test": "npm run test --workspace @audit-ai/admin",
    "format": "prettier --write \"apps/admin/**/*.{ts,tsx,css}\" \"packages/shared/**/*.ts\" \"scripts/**/*.ts\" \"docs/**/*.md\" \"data/**/*.md\" \".github/**/*.yml\" \"README.md\"",
    "format:check": "prettier --check \"apps/admin/**/*.{ts,tsx,css}\" \"packages/shared/**/*.ts\" \"scripts/**/*.ts\" \"docs/**/*.md\" \"data/**/*.md\" \".github/**/*.yml\" \"README.md\"",
    "sync:rule-embeddings": "tsx --tsconfig apps/admin/tsconfig.json scripts/sync-rule-embeddings.ts",
    "sync:rule-embeddings:rebuild": "tsx --tsconfig apps/admin/tsconfig.json scripts/sync-rule-embeddings.ts --rebuild",
    "sync:knowledge-links": "tsx --tsconfig apps/admin/tsconfig.json scripts/extract-knowledge-links.ts",
    "verify:semantic-cases": "tsx --tsconfig apps/admin/tsconfig.json scripts/verify-semantic-cases.ts",
    "validate:knowledge-excel": "tsx --tsconfig apps/admin/tsconfig.json scripts/validate-knowledge-excel.ts"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,json,md}": "prettier --write"
  }
}
